{% extends 'layout.html.twig' %}

{% block page_title %}Pacientes{% endblock %}
{% block page_subtitle %}Gestión del registro de pacientes{% endblock %}

{% block topbar_actions %}
    <a href="{{ path('pacientes_new') }}" class="btn btn--primary">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Nuevo paciente
    </a>
{% endblock %}

{% block content %}

{# ── SEARCH AND FILTERS ── #}
<div class="filters-bar">
    <div class="search-wrap">
        <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="text" class="search-input" placeholder="Buscar por nombre, DNI o CIC..." id="searchInput">
    </div>
    <div class="filters-wrap">
        <select class="filter-select" id="generoFilter">
            <option value="">Todos los géneros</option>
            <option value="Masculino">Masculino</option>
            <option value="Femenino">Femenino</option>
            <option value="No binario">No binario</option>
        </select>
        <select class="filter-select" id="ordenFilter">
            <option value="nombre">Ordenar por nombre</option>
            <option value="fecha">Ordenar por fecha</option>
            <option value="sesiones">Ordenar por sesiones</option>
        </select>
    </div>
</div>

{# ── TABLE ── #}
<div class="card">
    <div class="card__body card__body--table">
        <table class="table" id="pacientesTable">
            <thead>
                <tr>
                    <th>Paciente</th>
                    <th>DNI / CIC</th>
                    <th>Edad</th>
                    <th>Patología</th>
                    <th>Tratamiento</th>
                    <th>Sesiones</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                {% for paciente in pacientes ?? [] %}
                <tr class="table-row" data-nombre="{{ paciente.nombre }} {{ paciente.apellido1 }}" data-genero="{{ paciente.genero }}">
                    <td>
                        <div class="table-patient">
                            <div class="table-patient__avatar table-patient__avatar--lg">
                                {{ paciente.nombre|slice(0,1) }}{{ paciente.apellido1|slice(0,1) }}
                            </div>
                            <div>
                                <div class="table-patient__name">{{ paciente.nombre }} {{ paciente.apellido1 }} {{ paciente.apellido2 }}</div>
                                <div class="table-patient__sub">{{ paciente.genero }}</div>
                            </div>
                        </div>
                    </td>
                    <td>
                        <div class="table-ids">
                            <span class="badge badge--dni">{{ paciente.dni }}</span>
                            {% if paciente.cic %}
                                <span class="badge badge--cic">{{ paciente.cic }}</span>
                            {% endif %}
                        </div>
                    </td>
                    <td>{{ paciente.edad }} años</td>
                    <td>
                        <span class="tag-patologia" title="{{ paciente.patologia }}">
                            {{ paciente.patologia|length > 35 ? paciente.patologia|slice(0,35) ~ '...' : paciente.patologia }}
                        </span>
                    </td>
                    <td>
                        <div class="tratamiento-info">
                            <div class="tratamiento-canal">
                                <span class="canal-label">C1</span>
                                <span>{{ paciente.intensidad }}mA · {{ paciente.tiempoM }}min</span>
                            </div>
                            {% if paciente.intensidad2 > 0 %}
                            <div class="tratamiento-canal">
                                <span class="canal-label canal-label--2">C2</span>
                                <span>{{ paciente.intensidad2 }}mA · {{ paciente.tiempoM2 }}min</span>
                            </div>
                            {% endif %}
                        </div>
                    </td>
                    <td>
                        <span class="sesiones-count">{{ paciente.sesiones|length ?? 0 }}</span>
                    </td>
                    <td>
                        <div class="table-actions">
                            <a href="{{ path('pacientes_show', {id: paciente.id}) }}" class="table-action" title="Ver detalle">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                            </a>
                            <a href="{{ path('pacientes_edit', {id: paciente.id}) }}" class="table-action" title="Editar">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                            </a>
                            <button class="table-action table-action--danger" title="Eliminar" onclick="confirmDelete({{ paciente.id }}, '{{ paciente.nombre }} {{ paciente.apellido1 }}')">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
                            </button>
                        </div>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="7">
                        <div class="empty-table">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                            <p>No hay pacientes registrados</p>
                            <a href="{{ path('pacientes_new') }}" class="btn btn--primary btn--sm">Añadir primer paciente</a>
                        </div>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

{# ── DELETE MODAL ── #}
<div class="modal-overlay" id="deleteModal">
    <div class="modal">
        <div class="modal__icon modal__icon--danger">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
        </div>
        <h3 class="modal__title">Eliminar paciente</h3>
        <p class="modal__desc">¿Estás seguro de que quieres eliminar a <strong id="deletePatientName"></strong>? Esta acción no se puede deshacer y se eliminarán todas sus sesiones.</p>
        <div class="modal__actions">
            <button class="btn btn--ghost" onclick="closeModal()">Cancelar</button>
            <form id="deleteForm" method="post">
                <input type="hidden" name="_method" value="DELETE">
                <input type="hidden" name="_token" value="{{ csrf_token('delete') }}">
                <button type="submit" class="btn btn--danger">Sí, eliminar</button>
            </form>
        </div>
    </div>
</div>

{% endblock %}

{% block javascripts %}
<script>
// Búsqueda en tiempo real
document.getElementById('searchInput').addEventListener('input', function() {
    const q = this.value.toLowerCase();
    document.querySelectorAll('.table-row').forEach(row => {
        const nombre = row.dataset.nombre.toLowerCase();
        row.style.display = nombre.includes(q) ? '' : 'none';
    });
});

// Modal de confirmación de borrado
function confirmDelete(id, nombre) {
    document.getElementById('deletePatientName').textContent = nombre;
    document.getElementById('deleteForm').action = `/pacientes/${id}`;
    document.getElementById('deleteModal').classList.add('is-open');
}

function closeModal() {
    document.getElementById('deleteModal').classList.remove('is-open');
}

document.getElementById('deleteModal').addEventListener('click', function(e) {
    if (e.target === this) closeModal();
});
</script>
{% endblock %}
