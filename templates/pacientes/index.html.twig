{% extends 'layout.html.twig' %}

{% block page_title %}Pacientes{% endblock %}
{% block page_subtitle %}{{ totalPacientes }} paciente{{ totalPacientes != 1 ? 's' : '' }} registrado{{ totalPacientes != 1 ? 's' : '' }} en el sistema{% endblock %}

{% block topbar_actions %}
    <a href="{{ path('pacientes_new') }}" class="btn-primary">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
        </svg>
        Nuevo paciente
    </a>
{% endblock %}

{% block content %}

{# ── BARRA DE BÚSQUEDA Y FILTROS ── #}
<div class="filters-bar">
    <form method="get" action="{{ path('pacientes_index') }}" class="filters-form" id="filters-form">

        <div class="search-wrap">
            <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
            <input
                type="text"
                name="q"
                class="search-input"
                placeholder="Buscar por nombre, CIC o DNI…"
                value="{{ busqueda }}"
                autocomplete="off"
            >
            {% if busqueda %}
                <button type="button" class="search-clear" onclick="document.querySelector('[name=q]').value=''; document.getElementById('filters-form').submit()">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                </button>
            {% endif %}
        </div>

        <div class="filter-wrap">
            <svg class="filter-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/>
            </svg>
            <select name="patologia" class="filter-select" onchange="this.form.submit()">
                <option value="">Todas las patologías</option>
                {% for p in patologias %}
                    <option value="{{ p }}" {% if filtroPatologia == p %}selected{% endif %}>{{ p }}</option>
                {% endfor %}
            </select>
        </div>

        <button type="submit" class="btn-search">Buscar</button>

        {% if busqueda or filtroPatologia %}
            <a href="{{ path('pacientes_index') }}" class="btn-reset">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.19"/></svg>
                Limpiar
            </a>
        {% endif %}

    </form>

    <div class="filters-meta">
        {% if busqueda or filtroPatologia %}
            <span class="results-count">
                {{ pacientes|length }} resultado{{ pacientes|length != 1 ? 's' : '' }}
                {% if busqueda %} para <strong>"{{ busqueda }}"</strong>{% endif %}
                {% if filtroPatologia %} · <strong>{{ filtroPatologia }}</strong>{% endif %}
            </span>
        {% endif %}
    </div>
</div>

{# ── TABLA PACIENTES ── #}
<div class="card card--full">

    {% if pacientes|length > 0 %}
    <div class="table-responsive">
        <table class="table table--pacientes">
            <thead>
                <tr>
                    <th>Paciente</th>
                    <th>CIC / DNI</th>
                    <th>Edad</th>
                    <th>Patología</th>
                    <th>Protocolo</th>
                    <th>Sesiones</th>
                    <th>Última sesión</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                {% for p in pacientes %}
                <tr class="table-row--clickable" onclick="window.location='{{ path('pacientes_show', {id: p.id}) }}'">

                    {# Avatar + nombre #}
                    <td>
                        <div class="table-patient">
                            <div class="table-patient__avatar table-patient__avatar--{{ loop.index % 4 }}">
                                {{ p.nombre|slice(0,1) }}{{ p.apellido1|slice(0,1) }}
                            </div>
                            <div class="table-patient__info">
                                <span class="table-patient__name">{{ p.nombre }} {{ p.apellido1 }}{% if p.apellido2 %} {{ p.apellido2 }}{% endif %}</span>
                                <span class="table-patient__sub">{{ p.genero ?? '—' }}</span>
                            </div>
                        </div>
                    </td>

                    {# CIC / DNI #}
                    <td>
                        <div class="table-ids">
                            <span class="badge badge--cic">{{ p.cic }}</span>
                            <span class="table-ids__dni">{{ p.dni }}</span>
                        </div>
                    </td>

                    {# Edad #}
                    <td>
                        <span class="table-age">{{ p.edad ?? '—' }} <small>años</small></span>
                    </td>

                    {# Patología #}
                    <td>
                        <span class="badge badge--patologia">{{ p.patologia ?? '—' }}</span>
                    </td>

                    {# Protocolo (intensidad + tiempo) #}
                    <td>
                        <div class="protocol-cell">
                            <div class="protocol-channel">
                                <span class="protocol-label">Ch1</span>
                                <span class="protocol-values">{{ p.intensidad }}mA · {{ p.tiempo }}min</span>
                            </div>
                            {% if p.intensidad2 %}
                            <div class="protocol-channel">
                                <span class="protocol-label">Ch2</span>
                                <span class="protocol-values">{{ p.intensidad2 }}mA · {{ p.tiempo2 }}min</span>
                            </div>
                            {% endif %}
                        </div>
                    </td>

                    {# Total sesiones #}
                    <td>
                        <div class="sessions-count">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
                            </svg>
                            <span>{{ p.totalSesiones ?? 0 }}</span>
                        </div>
                    </td>

                    {# Última sesión #}
                    <td class="table-date">
                        {% if p.ultimaSesion %}
                            {{ p.ultimaSesion|date('d/m/Y') }}
                        {% else %}
                            <span class="text-muted">Sin sesiones</span>
                        {% endif %}
                    </td>

                    {# Acciones #}
                    <td onclick="event.stopPropagation()">
                        <div class="table-actions">
                            <a href="{{ path('pacientes_show', {id: p.id}) }}" class="table-action table-action--view" title="Ver ficha">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
                                </svg>
                            </a>
                            <a href="{{ path('pacientes_edit', {id: p.id}) }}" class="table-action table-action--edit" title="Editar">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                                </svg>
                            </a>
                        </div>
                    </td>

                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    {% else %}

    {# ── ESTADO VACÍO ── #}
    <div class="empty-state empty-state--full">
        <div class="empty-state__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
        </div>
        {% if busqueda or filtroPatologia %}
            <h3>Sin resultados</h3>
            <p>No hay pacientes que coincidan con los filtros aplicados.</p>
            <a href="{{ path('pacientes_index') }}" class="btn-primary btn-primary--sm">Limpiar filtros</a>
        {% else %}
            <h3>Aún no hay pacientes</h3>
            <p>Los pacientes se crean desde la app Android de los fisioterapeutas.</p>
            <a href="{{ path('pacientes_new') }}" class="btn-primary btn-primary--sm">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                Crear primer paciente
            </a>
        {% endif %}
    </div>

    {% endif %}

</div>

{% endblock %}

{% block javascripts %}
<script>
    // Búsqueda con debounce al escribir
    const searchInput = document.querySelector('.search-input');
    if (searchInput) {
        let timer;
        searchInput.addEventListener('input', () => {
            clearTimeout(timer);
            timer = setTimeout(() => {
                document.getElementById('filters-form').submit();
            }, 400);
        });
    }
</script>
{% endblock %}
