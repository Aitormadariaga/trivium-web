{% extends 'layout.html.twig' %}

{% block page_title %}{{ paciente.nombre ?? 'Paciente' }} {{ paciente.apellido1 ?? '' }}{% endblock %}
{% block page_subtitle %}Ficha clínica completa{% endblock %}

{% block topbar_actions %}
    <a href="{{ path('pacientes_index') }}" class="btn btn--ghost">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
        Volver
    </a>
    <a href="{{ path('pacientes_edit', {id: paciente.id}) }}" class="btn btn--primary">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
        Editar
    </a>
{% endblock %}

{% block content %}

<div class="detail-grid">

    {# ── COLUMNA IZQUIERDA ── #}
    <div class="detail-sidebar">

        {# Tarjeta de identidad #}
        <div class="card profile-card">
            <div class="profile-card__avatar">
                {{ paciente.nombre ? paciente.nombre|slice(0,1) : 'P' }}{{ paciente.apellido1 ? paciente.apellido1|slice(0,1) : '' }}
            </div>
            <h2 class="profile-card__name">
                {{ paciente.nombre }} {{ paciente.apellido1 }}{% if paciente.apellido2 is not null %} {{ paciente.apellido2 }}{% endif %}
            </h2>
            <div class="profile-card__badges">
                <span class="badge badge--dni">{{ paciente.dni }}</span>
                {% if paciente.cic is not null %}<span class="badge badge--cic">{{ paciente.cic }}</span>{% endif %}
            </div>
            <div class="profile-card__meta">
                <div class="profile-meta-item">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    <span>{{ paciente.edad ?? '—' }} años</span>
                </div>
                <div class="profile-meta-item">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                    <span>{{ paciente.genero ?? '—' }}</span>
                </div>
            </div>
        </div>

        {# Parámetros de tratamiento #}
        <div class="card">
            <div class="card__header">
                <h3 class="card__title">Parámetros de tratamiento</h3>
            </div>
            <div class="card__body">

                <div class="canal-block">
                    <div class="canal-header">
                        <span class="canal-badge canal-badge--1">Canal 1</span>
                    </div>
                    <div class="canal-params">
                        <div class="param-item">
                            <span class="param-label">Intensidad</span>
                            <span class="param-value">{{ paciente.intensidad ?? '—' }} mA</span>
                        </div>
                        <div class="param-item">
                            <span class="param-label">Tiempo</span>
                            <span class="param-value">{{ paciente.tiempo ?? '—' }} min</span>
                        </div>
                    </div>
                    {% if paciente.intensidad %}
                    <div class="param-bar">
                        {% set pct1 = (paciente.intensidad / 20) * 100 %}
                        <div class="param-bar__fill" style="width: {{ pct1 > 100 ? 100 : pct1 }}%"></div>
                    </div>
                    {% endif %}
                </div>

                {% if paciente.intensidad2 %}
                <div class="canal-block">
                    <div class="canal-header">
                        <span class="canal-badge canal-badge--2">Canal 2</span>
                    </div>
                    <div class="canal-params">
                        <div class="param-item">
                            <span class="param-label">Intensidad</span>
                            <span class="param-value">{{ paciente.intensidad2 }} mA</span>
                        </div>
                        <div class="param-item">
                            <span class="param-label">Tiempo</span>
                            <span class="param-value">{{ paciente.tiempo2 ?? '—' }} min</span>
                        </div>
                    </div>
                    <div class="param-bar">
                        {% set pct2 = (paciente.intensidad2 / 20) * 100 %}
                        <div class="param-bar__fill param-bar__fill--2" style="width: {{ pct2 > 100 ? 100 : pct2 }}%"></div>
                    </div>
                </div>
                {% endif %}

            </div>
        </div>

    </div>

    {# ── COLUMNA DERECHA ── #}
    <div class="detail-main">

        {# Información clínica #}
        <div class="card">
            <div class="card__header">
                <h3 class="card__title">Información clínica</h3>
            </div>
            <div class="card__body">
                <div class="info-grid">
                    <div class="info-item info-item--full">
                        <span class="info-label">Patología</span>
                        <p class="info-value">{{ paciente.patologia ?? '—' }}</p>
                    </div>
                    <div class="info-item info-item--full">
                        <span class="info-label">Medicación</span>
                        <p class="info-value">{{ paciente.medicacion ?? '—' }}</p>
                    </div>
                </div>
            </div>
        </div>

        {# Historial de sesiones #}
        <div class="card">
            <div class="card__header">
                <h3 class="card__title">Historial de sesiones</h3>
                <span class="card__count">{{ paciente.sesiones|length }} sesiones</span>
            </div>
            <div class="card__body card__body--table">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Fecha</th>
                            <th>Dispositivo</th>
                            <th>Intensidad</th>
                            <th>Duración</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for sesion in paciente.sesiones %}
                        <tr>
                            <td class="table-date">{{ sesion.fecha|date('d/m/Y H:i') }}</td>
                            <td><span class="badge badge--device">{{ sesion.dispositivo }}</span></td>
                            <td>
                                <div class="intensity-bar">
                                    {% set pctS = (sesion.intensidad / 20) * 100 %}
                                    <div class="intensity-bar__fill" style="width: {{ pctS > 100 ? 100 : pctS }}%"></div>
                                    <span>{{ sesion.intensidad }} mA</span>
                                </div>
                            </td>
                            <td>{{ sesion.tiempo }} min</td>
                        </tr>
                        {% else %}
                        <tr>
                            <td colspan="4" class="table-empty">Sin sesiones registradas</td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>

    </div>
</div>

{% endblock %}
