{% extends 'base.html.twig' %}

{% block body %}
<div class="layout">

    {# ── SIDEBAR ── #}
    <aside class="sidebar">
        <div class="sidebar__logo">
            <div class="sidebar__logo-icon">
                <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M16 3L16 29M3 16H29M8 8L24 24M24 8L8 24" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
                </svg>
            </div>
            <span>TRIVIUM</span>
        </div>

        <nav class="sidebar__nav">
            <div class="sidebar__section-label">Principal</div>
            <a href="{{ path('dashboard') }}" class="sidebar__link {% if app.request.attributes.get('_route') == 'dashboard' %}is-active{% endif %}">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
                <span>Dashboard</span>
            </a>
            <a href="{{ path('pacientes_index') }}"
                class="sidebar__link {% if app.request.attributes.get('_route') starts with 'pacientes' %}is-active{% endif %}">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                <span>Pacientes</span>
            </a>
            <a href="{{ path('sesiones_index') }}"
                class="sidebar__link {% if app.request.attributes.get('_route') starts with 'sesiones' %}is-active{% endif %}">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
                <span>Sesiones</span>
            </a>

            <div class="sidebar__section-label">Administración</div>
            <a href="#" class="sidebar__link">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                <span>Usuarios</span>
            </a>
            <a href="#" class="sidebar__link">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
                <span>Dispositivos</span>
            </a>
        </nav>

        <div class="sidebar__user">
            <div class="sidebar__user-avatar">A</div>
            <div class="sidebar__user-info">
                <span class="sidebar__user-name">Administrador</span>
                <span class="sidebar__user-role">admin</span>
            </div>
            <a href="#" class="sidebar__logout" title="Cerrar sesión">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
            </a>
        </div>
    </aside>

    {# ── MAIN CONTENT ── #}
    <main class="main">
        <header class="topbar">
            <div class="topbar__left">
                <h1 class="topbar__title">{% block page_title %}{% endblock %}</h1>
                <p class="topbar__subtitle">{% block page_subtitle %}{% endblock %}</p>
            </div>
            <div class="topbar__right">
                {% block topbar_actions %}{% endblock %}
            </div>
        </header>

        {# Flash messages #}
        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert--{{ type }}">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        {% if type == 'success' %}<polyline points="20 6 9 17 4 12"/>
                        {% elseif type == 'danger' %}<circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
                        {% else %}<circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/>{% endif %}
                    </svg>
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        <div class="content">
            {% block content %}{% endblock %}
        </div>
    </main>

</div>
{% endblock %}