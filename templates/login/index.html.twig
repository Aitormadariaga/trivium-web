{% extends 'base.html.twig' %}
{% block title %}Acceso{% endblock %}

{% block body %}
<div class="login-page">

    {# ── Panel izquierdo (decorativo) ── #}
    <div class="login-left">
        <div class="login-left__content">
            <div class="login-brand">
                <div class="login-brand__icon">
                    <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M16 3L16 29M3 16H29M8 8L24 24M24 8L8 24" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
                    </svg>
                </div>
                <span class="login-brand__name">TRIVIUM</span>
            </div>

            <div class="login-hero">
                <h1 class="login-hero__title">Panel de<br>Gestión Clínica</h1>
                <p class="login-hero__desc">Monitorización y gestión centralizada de pacientes y sesiones de electroterapia.</p>
            </div>



        <div class="login-left__bg">
            <div class="bg-circle bg-circle--1"></div>
            <div class="bg-circle bg-circle--2"></div>
            <div class="bg-pulse"></div>
        </div>
    </div>

    {# ── Panel derecho (formulario) ── #}
    <div class="login-right">
        <div class="login-card">

            {# Cabecera #}
            <div class="login-card__header">
                <h2 class="login-card__title">Iniciar sesión</h2>
                <p class="login-card__sub">Accede con tus credenciales</p>
            </div>

            {# Flash messages #}
            {% for type, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert--{{ type }}" style="margin-bottom: 16px;">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            {% if type == 'success' %}<polyline points="20 6 9 17 4 12"/>
                            {% elseif type == 'danger' %}<circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
                            {% else %}<circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/>{% endif %}
                        </svg>
                        {{ message }}
                    </div>
                {% endfor %}
            {% endfor %}

            {# Error de autenticación #}
            {% if error %}
                <div class="alert alert--danger" style="margin-bottom: 16px;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"/>
                        <line x1="12" y1="8" x2="12" y2="12"/>
                        <line x1="12" y1="16" x2="12.01" y2="16"/>
                    </svg>
                    {{ error.messageKey|trans(error.messageData, 'security') }}
                </div>
            {% endif %}

            {# Formulario #}
            <form class="login-form" action="{{ path('app_login') }}" method="post">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                {# Usuario #}
                <div class="form-group">
                    <label class="form-label" for="username">Usuario</label>
                    <div class="form-input-wrap">
                        <svg class="form-input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                            <circle cx="12" cy="7" r="4"/>
                        </svg>
                        <input
                            class="form-input"
                            type="text"
                            id="username"
                            name="_username"
                            value="{{ last_username }}"
                            autocomplete="username"
                            placeholder="Tu nombre de usuario"
                            required
                            autofocus
                        >
                    </div>
                </div>

                {# Contraseña #}
                <div class="form-group">
                    <label class="form-label" for="password">Contraseña</label>
                    <div class="form-input-wrap">
                        <svg class="form-input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                            <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                        </svg>
                        <input
                            class="form-input"
                            type="password"
                            id="password"
                            name="_password"
                            autocomplete="current-password"
                            placeholder="Tu contraseña"
                            required
                        >
                        <button type="button" class="form-input-toggle" onclick="togglePassword()" aria-label="Mostrar contraseña">
                            <svg id="icon-eye" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                <circle cx="12" cy="12" r="3"/>
                            </svg>
                            <svg id="icon-eye-off" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none;">
                                <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/>
                                <path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/>
                                <line x1="1" y1="1" x2="23" y2="23"/>
                            </svg>
                        </button>
                    </div>
                </div>

                {# Mantener sesión iniciada ── NUEVO ── #}
                <div class="form-group form-group--inline">
                    <label class="form-checkbox" for="remember_me">
                        <input
                            type="checkbox"
                            id="remember_me"
                            name="_remember_me"
                            value="1"
                            class="form-checkbox__input"
                        >
                        <span class="form-checkbox__box"></span>
                        <span class="form-checkbox__label">Mantener sesión iniciada</span>
                    </label>
                </div>

                <button type="submit" class="btn-login">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/>
                        <polyline points="10 17 15 12 10 7"/>
                        <line x1="15" y1="12" x2="3" y2="12"/>
                    </svg>
                    Entrar
                </button>
            </form>

            {# Footer del card #}
            <div class="login-card__footer">
                <p>¿No tienes cuenta? <a href="{{ path('app_registro') }}" class="login-card__link">Crear cuenta</a></p>
            </div>

        </div>
    </div>

</div>

<script>
function togglePassword() {
    const input   = document.getElementById('password');
    const iconOn  = document.getElementById('icon-eye');
    const iconOff = document.getElementById('icon-eye-off');
    const isText  = input.type === 'text';
    input.type    = isText ? 'password' : 'text';
    iconOn.style.display  = isText ? '' : 'none';
    iconOff.style.display = isText ? 'none' : '';
}
</script>
{% endblock %}
