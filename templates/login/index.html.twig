{% extends 'base.html.twig' %}
{% block title %}Acceso{% endblock %}

{% block body %}
<div class="login-page">

    <div class="login-left">
        <div class="login-left__content">
            <div class="login-brand">
                <div class="login-brand__icon">
                    <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M16 3L16 29M3 16H29M8 8L24 24M24 8L8 24" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
                    </svg>
                </div>
                <span class="login-brand__name">TRIVIUM</span>
            </div>

            <div class="login-hero">
                <h1 class="login-hero__title">Panel de<br>Gestión Clínica</h1>
                <p class="login-hero__desc">Monitorización y gestión centralizada de pacientes y sesiones de electroterapia.</p>
            </div>

            <div class="login-stats">
                <div class="login-stat">
                    <span class="login-stat__value">99.9%</span>
                    <span class="login-stat__label">Disponibilidad</span>
                </div>
                <div class="login-stat">
                    <span class="login-stat__value">SHA-256</span>
                    <span class="login-stat__label">Cifrado</span>
                </div>
                <div class="login-stat">
                    <span class="login-stat__value">RGPD</span>
                    <span class="login-stat__label">Cumplimiento</span>
                </div>
            </div>
        </div>

        <div class="login-left__bg">
            <div class="bg-circle bg-circle--1"></div>
            <div class="bg-circle bg-circle--2"></div>
            <div class="bg-pulse"></div>
        </div>
    </div>

    <div class="login-right">
        <div class="login-form-wrap">
            <div class="login-form__header">
                <h2>Iniciar sesión</h2>
                <p>Introduce tus credenciales para acceder al panel</p>
            </div>

            {% if error %}
                <div class="alert alert--danger">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                    {{ error.messageKey|trans(error.messageData, 'security') }}
                </div>
            {% endif %}

            <form class="login-form" method="post">
                <div class="form-group">
                    <label class="form-label" for="username">Usuario</label>
                    <div class="form-input-wrap">
                        <svg class="form-input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                        <input
                            type="text"
                            id="username"
                            name="_username"
                            class="form-input"
                            value="{{ last_username }}"
                            autocomplete="username"
                            placeholder="Nombre de usuario"
                            required
                            autofocus
                        >
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label" for="password">
                        Contraseña
                    </label>
                    <div class="form-input-wrap">
                        <svg class="form-input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                        <input
                            type="password"
                            id="password"
                            name="_password"
                            class="form-input"
                            autocomplete="current-password"
                            placeholder="••••••••"
                            required
                        >
                        <button type="button" class="form-input-toggle" onclick="togglePassword()" title="Mostrar/ocultar contraseña">
                            <svg id="eye-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                        </button>
                    </div>
                </div>

                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                <button type="submit" class="btn-login">
                    <span>Acceder al panel</span>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </button>
            </form>

            <p class="login-form__footer">
                Panel restringido a personal autorizado.<br>
                Contacta con el administrador para obtener acceso.
            </p>
        </div>
    </div>

</div>

<script>
function togglePassword() {
    const input = document.getElementById('password');
    input.type = input.type === 'password' ? 'text' : 'password';
}
</script>
{% endblock %}
