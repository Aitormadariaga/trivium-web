{% extends 'layout.html.twig' %}

{% block page_title %}Dashboard{% endblock %}
{% block page_subtitle %}Resumen general del sistema{% endblock %}

{% block topbar_actions %}
    <div class="topbar__date">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        <span id="current-date"></span>
    </div>
{% endblock %}

{% block content %}

{# ── STAT CARDS ── #}
<div class="stats-grid">
    <div class="stat-card stat-card--blue">
        <div class="stat-card__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </div>
        <div class="stat-card__body">
            <span class="stat-card__value">{{ totalPacientes ?? '—' }}</span>
            <span class="stat-card__label">Pacientes registrados</span>
        </div>
        <div class="stat-card__trend stat-card__trend--up">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
            +{{ nuevosEsteMes ?? '0' }} este mes
        </div>
    </div>

    <div class="stat-card stat-card--cyan">
        <div class="stat-card__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
        </div>
        <div class="stat-card__body">
            <span class="stat-card__value">{{ totalSesiones ?? '—' }}</span>
            <span class="stat-card__label">Sesiones realizadas</span>
        </div>
        <div class="stat-card__trend stat-card__trend--up">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
            +{{ sesionesEsteMes ?? '0' }} este mes
        </div>
    </div>

    <div class="stat-card stat-card--slate">
        <div class="stat-card__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        </div>
        <div class="stat-card__body">
            <span class="stat-card__value">{{ totalUsuarios ?? '—' }}</span>
            <span class="stat-card__label">Usuarios activos</span>
        </div>
        <div class="stat-card__trend stat-card__trend--neutral">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Sin cambios
        </div>
    </div>

    <div class="stat-card stat-card--green">
        <div class="stat-card__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
        </div>
        <div class="stat-card__body">
            <span class="stat-card__value">{{ dispositivosActivos ?? '—' }}</span>
            <span class="stat-card__label">Dispositivos conectados</span>
        </div>
        <div class="stat-card__trend stat-card__trend--up">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            Última sync: hace 5 min
        </div>
    </div>
</div>

{# ── MAIN GRID ── #}
<div class="dashboard-grid">

    {# Últimas sesiones #}
    <div class="card card--wide">
        <div class="card__header">
            <h3 class="card__title">Últimas sesiones</h3>
            <a href="#" class="card__link">Ver todas</a>
        </div>
        <div class="card__body">
            <table class="table">
                <thead>
                    <tr>
                        <th>Paciente</th>
                        <th>Dispositivo</th>
                        <th>Intensidad</th>
                        <th>Duración</th>
                        <th>Fecha</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    {% for sesion in ultimasSesiones ?? [] %}
                    <tr>
                        <td>
                            <div class="table-patient">
                                <div class="table-patient__avatar">{{ sesion.paciente.nombre|slice(0,1) }}</div>
                                <span>{{ sesion.paciente.nombre }} {{ sesion.paciente.apellido1 }}</span>
                            </div>
                        </td>
                        <td><span class="badge badge--device">{{ sesion.dispositivo }}</span></td>
                        <td>
                            <div class="intensity-bar">
                                <div class="intensity-bar__fill" style="width: {{ (sesion.intensidad / 20 * 100)|round }}%"></div>
                                <span>{{ sesion.intensidad }} mA</span>
                            </div>
                        </td>
                        <td>{{ sesion.tiempo }} min</td>
                        <td class="table-date">{{ sesion.fecha|date('d/m/Y H:i') }}</td>
                        <td>
                            <a href="{{ path('sesiones_show', {id: sesion.id}) }}" class="table-action">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                            </a>
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="6" class="table-empty">No hay sesiones registradas aún</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    {# Pacientes recientes #}
    <div class="card">
        <div class="card__header">
            <h3 class="card__title">Pacientes recientes</h3>
            <a href="#" class="card__link">Ver todos</a>
        </div>
        <div class="card__body card__body--scroll">
            {% for paciente in pacientesRecientes ?? [] %}
            <div class="patient-item">
                <div class="patient-item__avatar">{{ paciente.nombre|slice(0,1) }}{{ paciente.apellido1|slice(0,1) }}</div>
                <div class="patient-item__info">
                    <span class="patient-item__name">{{ paciente.nombre }} {{ paciente.apellido1 }}</span>
                    <span class="patient-item__meta">{{ paciente.patologia|length > 30 ? paciente.patologia|slice(0,30) ~ '...' : paciente.patologia }}</span>
                </div>
                <a href="{{ path('pacientes_show', {id: paciente.id}) }}" class="patient-item__link">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                </a>
            </div>
            {% else %}
            <p class="empty-state">No hay pacientes registrados</p>
            {% endfor %}
        </div>
    </div>

</div>

{% endblock %}

{% block javascripts %}
<script>
    const d = new Date();
    document.getElementById('current-date').textContent =
        d.toLocaleDateString('es-ES', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
</script>
{% endblock %}
